# 환경변수 예시 파일. 실제 값은 .env.local 에 작성하세요 (gitignore 처리됨).
# Vite 는 VITE_ 접두사가 붙은 변수만 클라이언트 코드에 노출합니다.
# 참고: https://vite.dev/guide/env-and-mode

# 백엔드 API 베이스 URL — 카카오 로그인 시작·API 호출에 사용
VITE_API_BASE_URL=http://localhost:8080

# 카카오 지도 SDK 키 (JavaScript 키)
# ※ 로그인용 REST 키·redirect_uri 는 백엔드가 소유 (프론트엔드 불필요)
VITE_KAKAO_JS_KEY=

# 개발 중 MSW(Mock Service Worker) 브라우저 mock 활성화 — 'true' 일 때만 시작
# VITE_ENABLE_MSW=true
