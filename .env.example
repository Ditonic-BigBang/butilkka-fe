# 환경변수 예시 파일. 실제 값은 .env.local 에 작성하세요 (gitignore 처리됨).
# Vite 는 VITE_ 접두사가 붙은 변수만 클라이언트 코드에 노출합니다.
# 참고: https://vite.dev/guide/env-and-mode

# 백엔드 API 베이스 URL — 카카오 로그인 시작·API 호출에 사용
# 프로덕션: https://api.butilkka.site (실값은 Vercel 대시보드 환경변수로 설정)
VITE_API_BASE_URL=http://localhost:8080

# 카카오 지도 SDK 키 (JavaScript 키)
# ※ 로그인용 REST 키·redirect_uri 는 백엔드가 소유 (프론트엔드 불필요)
VITE_KAKAO_JS_KEY=

# MSW(Mock Service Worker) 브라우저 mock 활성화 — 'true' 일 때만 시작 (기본 꺼짐)
# - 로컬: 백엔드(butilkka-be, ./gradlew bootRun) 없이 UI 작업할 때 켜기
# - 배포(Vercel): 백엔드 배포 전 mock 데모용으로 켜고, 실서버 전환 시 제거
# VITE_ENABLE_MSW=true
